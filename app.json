{
  "expo": {
    "name": "FlickMV",
    "slug": "flickmv",
    "scheme": "flickmv",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#08080a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.flickmv.app"
    },
    "android": {
      "package": "com.flickmv.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#08080a"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "color": "#9333ea"
        }
      ],
      "@sentry/react-native/expo"
    ]
  }
}
