# ── CI/CD Secrets (GitHub → Settings → Secrets & Variables → Actions) ─

# Supabase
# SUPABASE_ACCESS_TOKEN        = sbp_...   (personal access token, shared across envs)
# SUPABASE_PROJECT_REF_STAGING = abcd1234  (dev Supabase project)
# SUPABASE_PROJECT_REF_PROD    = efgh5678  (prod Supabase project)
# VITE_SUPABASE_URL_STAGING    = https://<staging>.supabase.co
# VITE_SUPABASE_ANON_KEY_STAGING = eyJh...
# VITE_SUPABASE_URL_PROD       = https://<prod>.supabase.co
# VITE_SUPABASE_ANON_KEY_PROD  = eyJh...

# Vercel
# VERCEL_TOKEN     = ...
# VERCEL_ORG_ID    = team_...
# VERCEL_PROJECT_ID = prj_...
